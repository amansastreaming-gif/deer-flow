# config.yaml.template – Template de configuration DeerFlow pour Render
backend: postgres

checkpointer:
  backend: postgres
  connection_string: ${DATABASE_URL}

models:
  - name: groq-llama
    display_name: Llama 3.3 70B
    use: langchain_openai:ChatOpenAI
    model: llama-3.3-70b-versatile
    api_key: $GROQ_API_KEY
    base_url: https://api.groq.com/openai/v1
    request_timeout: 600.0
    max_retries: 2
    max_tokens: 8192
    temperature: 0.7
    supports_vision: false

# Conserve ici le reste des sections de l'ancien config.example.yaml
# (par exemple channels, etc.) sans les modifier, puisque ce sont des réglages
# qui ne dépendent pas des données sensibles.
# Tu peux simplement copier-coller les autres sections du fichier config.example.yaml
# après ce bloc, en prenant soin de ne pas dupliquer backend, checkpointer et models.
# Si tu ne vois pas d'autres sections, tu peux laisser le fichier comme ceci.
